# ── Runtime output directories ────────────────────────────────────────────────
# These are generated at scan time and may contain sensitive target data.
# Never commit scan results, reports, charts, or logs to version control.

exports/
reports/
charts/
logs/

# Keep the directory structure but ignore contents
# (add a .gitkeep inside each folder if you want the folders tracked)

# ── Scan result files (if accidentally placed in root) ─────────────────────────
scan_results_*.json
scan_results_*.csv
vulnerability_report_*.pdf

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
*.key
*.pem

# ── IDE & editor files ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db